<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecommerce.repository.ProductMapper">

    <resultMap id="productMap" type="com.ecommerce.domain.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="category" column="category"/>
        <result property="image" column="image"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findAll" resultMap="productMap">
        SELECT * FROM product WHERE status = 'ON' ORDER BY create_time DESC
    </select>

    <select id="findByCategory" resultMap="productMap">
        SELECT * FROM product WHERE status = 'ON' AND category = #{category} ORDER BY create_time DESC
    </select>

    <select id="findById" resultMap="productMap">
        SELECT * FROM product WHERE id = #{id}
    </select>

    <select id="search" resultMap="productMap">
        SELECT * FROM product WHERE status = 'ON'
        AND (name LIKE '%' || #{keyword} || '%' OR description LIKE '%' || #{keyword} || '%')
        ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.ecommerce.domain.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, description, price, stock, category, image, status)
        VALUES (#{name}, #{description}, #{price}, #{stock}, #{category}, #{image}, #{status})
    </insert>

    <update id="update" parameterType="com.ecommerce.domain.Product">
        UPDATE product
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="category != null">category = #{category},</if>
            <if test="image != null">image = #{image},</if>
            <if test="status != null">status = #{status},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM product WHERE id = #{id}
    </delete>
</mapper>
